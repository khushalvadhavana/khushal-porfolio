{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/client/dist/assets/$1"
    },
    {
      "source": "/(favicon.svg|vite.svg|.*\\.pdf|.*\\.jpg|.*\\.png|.*\\.ico)",
      "destination": "/client/dist/$1"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/client/dist/index.html"
    }
  ]
}